{
  "name": "busseuk",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "prettier --write",
      "pnpm --filter web exec eslint --fix"
    ],
    "apps/web/**/*.css": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "turbo": "latest"
  },
  "packageManager": "pnpm@10.29.2"
}
